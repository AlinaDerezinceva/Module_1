//4 В файле /etc/passwd найдите всех пользователей в системе, у которых установлен shell
/usr/sbin/nologin и выведите их в виде списка: «UID, username, список его групп»,
отсортированный в обратном порядке по UID, cписок групп используйте из файла /etc/group

touch /tmp/task4.sh
nano /tmp/task4.sh

#!/bin/bash
grep "/usr/sbin/nologin" /etc/passwd | \
while IFS=: read -r user _ uid gid _ _ _; do
    primary=$(awk -F: -v gid="$gid" '$3==gid{print $1}' /etc/group)
    extra=$(awk -F: -v user="$user" '$4~user{if(g)g=g",";g=g$1}END{print g}' /etc/group)
    [ -n "$extra" ] && groups="$primary,$extra" || groups="$primary"
    echo "$uid, $user, $groups"
done | sort -t, -k1 -rn

chmod +x /tmp/task4.sh
/tmp/task4.sh

