//1 Найдите все записи из лога загрузки, доступного через команду journalctl с опцией -b в первые
20 секунд с момента загрузки, начало загрузки определить автоматически.

BTIME=$(awk /btime/ {print } /proc/stat)
BOOT_TIME=$(date -u -d "@$BTIME" +%Y-%m-%d %H:%M:%S)
UNTIL=$(date -u -d "@$((BTIME + 20))" +%Y-%m-%d %H:%M:%S)
$BOOT_TIME
2026-03-12 08:28:03
$UNTIL
2026-03-12 08:28:23

journalctl -b --utc --since "$BOOT_TIME" --until "$UNTIL" --no-pager
