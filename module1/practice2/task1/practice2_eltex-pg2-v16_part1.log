//4 создание пользователя user1 и создание пароля
useradd -m -s /bin/bash user1
passwd user1

//5 создать пользователя user2 и user3
adduser user2
adduser user3

//6 для пользователя user3 сменить shell на /usr/sbin/nologin 
usermod -s /usr/sbin/nologin user3
//выполнить вход при помощи утилиты su без доп.параметров
su - user3

This account is currently not available.

//выполнить вход с явным указанием shell /bin/bash в параметрах su
su -s /bin/bash user3

exit

//7 создать новую группу и добавить её для всех пользователей user* как дополнительную
groupadd onegroup
usermod -aG onegroup user1
usermod -aG onegroup user2
usermod -aG onegroup user3

//посмотреть список групп всех пользователей
id user1
uid=1001(user1) gid=1001(user1) groups=1001(user1),1004(onegroup)

id user2
uid=1002(user2) gid=1002(user2) groups=1002(user2),100(users),1004(onegroup)

id user3
uid=1003(user3) gid=1003(user3) groups=1003(user3),100(users),1004(onegroup)

//9 создайте каталог  /opt/share и назначить группу из предыдущего пункта его владельцем, установить на этот каталог бит SGID
 
mkdir -p /opt/share

chgrp onegroup /opt/share
chmod g+s,g+rwx /opt/share

//10 ДЛЯ user1 задать перманентно umask, снимающий права чтения для прочих
echo "umask 027" >> /home/user1/.bashrc

//11 создать пользователям новые файлы в каталоге /opt/share, удалить файлы созданные другими пользователями

su - user1
touch /opt/share/file_user1.txt
exit

su - user2
touch /opt/share/file_user2.txt
exit

su -s /bin/bash user3
touch /opt/share/file_user3.txt
exit

ls -la /opt/share

